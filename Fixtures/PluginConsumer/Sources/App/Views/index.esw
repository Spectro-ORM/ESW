<%!
var title: String = "Welcome"
var items: [String] = []
%>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title><%= title %></title>
  </head>
  <body>
    <h1><%= title %></h1>
<% if items.isEmpty { %>
    <p>No items yet.</p>
<% } else { %>
    <ul>
<% for item in items { %>
      <li><%= item %></li>
<% } %>
    </ul>
<% } %>
  </body>
</html>
